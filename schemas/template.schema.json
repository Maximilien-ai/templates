{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Maximilien-ai/templates/schemas/template.schema.json",
  "title": "Organization Template",
  "type": "object",
  "required": [
    "name",
    "type",
    "version",
    "description",
    "agents",
    "communities",
    "groups",
    "workflows"
  ],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "organization",
        "agent"
      ]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": [
        "business",
        "technical",
        "personal",
        "science",
        "travel",
        "hobbies",
        "family"
      ]
    },
    "author": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "testedWith": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/testedPlatform"
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/parameter"
      }
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent"
      }
    },
    "communities": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/community"
      }
    },
    "groups": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/group"
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow"
      }
    }
  },
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "kebabId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "parameter": {
      "type": "object",
      "required": [
        "agentId",
        "label",
        "default",
        "min",
        "max"
      ],
      "properties": {
        "agentId": {
          "$ref": "#/$defs/kebabId"
        },
        "label": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "default": {
          "type": "integer"
        },
        "min": {
          "type": "integer"
        },
        "max": {
          "type": "integer"
        }
      },
      "additionalProperties": true
    },
    "testedPlatform": {
      "type": "object",
      "required": [
        "platform",
        "version"
      ],
      "properties": {
        "platform": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "version": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "agent": {
      "type": "object",
      "required": [
        "id",
        "name",
        "role"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "role": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "communities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "template": {
          "$ref": "#/$defs/nonEmptyString"
        }
      },
      "additionalProperties": true
    },
    "community": {
      "type": "object",
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "additionalProperties": true
    },
    "group": {
      "type": "object",
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "community": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "channels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "additionalProperties": true
    },
    "workflowTargeting": {
      "type": "object",
      "properties": {
        "communities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "groups": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "agents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        }
      },
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "required": [
        "name",
        "schedule",
        "executionMode",
        "content"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/kebabId"
        },
        "name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "description": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "schedule": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "enabled": {
          "type": "boolean"
        },
        "executionMode": {
          "type": "string",
          "enum": [
            "automated",
            "managed"
          ]
        },
        "owner": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "targeting": {
          "$ref": "#/$defs/workflowTargeting"
        },
        "content": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "dependsOn": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "type": {
          "type": "string",
          "enum": [
            "once",
            "recurring",
            "conditional"
          ]
        },
        "scaling": {
          "type": "string",
          "enum": [
            "singleton",
            "parallel"
          ]
        },
        "parallelism": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
